# ==============================================================================
# RAG Chatbot Dokumen Perusahaan - Environment Variables
# ==============================================================================

# Common
PROJECT_NAME="RAG Chatbot Dokumen Perusahaan"
ENVIRONMENT=development

# Database (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_chatbot
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_chatbot

# Security & JWT
JWT_SECRET=supersecretjwtkeychangeinproduction12345!@#$
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI & Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Vector DB (Chroma)
CHROMA_PERSIST_DIRECTORY=./chroma_db

# File Storage
UPLOAD_DIR=./uploads

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
